# Senha de acesso ao painel
APP_PASSWORD=minha-senha-segura
APP_SECRET=chave-secreta-para-cookie-hmac

# Meta WhatsApp Business API
META_PHONE_NUMBER_ID=123456789012345
META_WABA_ID=123456789012345
META_ACCESS_TOKEN=EAAxxxxxxxx
META_WEBHOOK_VERIFY_TOKEN=meu-token-verificacao

# HubSpot
HUBSPOT_ACCESS_TOKEN=pat-xx-xxxxxxxx

# Classificacao com Claude (opcional — sem isso, classificacao fica desativada)
CLAUDE_API_KEY=sk-ant-xxxxxxxx

# Numeros internos — separados por virgula, sem + (descartados silenciosamente)
INTERNAL_PHONES=5511999999999,5537999999999

# Banco de dados (SQLite)
DATABASE_URL=file:./data/whatsapp-mkt.db

# URL publica do app (para redirects)
NEXT_PUBLIC_APP_URL=http://campanhas-whatsapp-mkt.apps.wmi.solutions
